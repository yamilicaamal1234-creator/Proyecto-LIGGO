@page "/incidents"
@inject AuthService Auth
@inject NavigationManager Nav
@inject IncidentService IncidentService
@inject PlayerService PlayerService

<div class="space-y-8">
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-3xl font-black text-[#0A1F44]">Incidentes</h1>
            <p class="text-slate-500 font-medium">Reporte de sanciones, lesiones y eventos administrativos.</p>
        </div>
        <button @onclick="ShowCreateModal" class="bg-[#0A1F44] hover:bg-[#0B6623] text-white px-6 py-3 rounded-xl font-bold transition-all shadow-lg shadow-[#0A1F44]/20 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Reportar Incidente
        </button>
    </div>

    @* Bitácora *@
    <div class="space-y-6">
        @if (incidents == null || !incidents.Any())
        {
            <div class="bg-white rounded-[2rem] p-12 text-center shadow-[0_4px_20px_rgba(0,0,0,0.03)] border border-slate-50">
                <p class="text-slate-400 font-bold uppercase tracking-widest text-sm">No hay incidentes registrados</p>
                <p class="text-slate-500 mt-2">Los nuevos reportes aparecerán aquí.</p>
            </div>
        }
        else
        {
            @foreach (var inc in incidents)
            {
                var iconColor = inc.Severity switch {
                    "Major" => "text-red-500 bg-red-50",
                    "Moderate" => "text-amber-500 bg-amber-50",
                    _ => "text-blue-500 bg-blue-50"
                };

                <div class="bg-white rounded-[2rem] p-6 shadow-[0_4px_20px_rgba(0,0,0,0.03)] border border-slate-50 transition-all hover:shadow-[0_15px_30px_rgba(0,0,0,0.05)]">
                    <div class="flex items-start gap-6">
                        <div class="h-14 w-14 shrink-0 rounded-2xl flex items-center justify-center @iconColor">
                            @if (inc.Severity == "Major") {
                                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
                            } else if (inc.Severity == "Moderate") {
                                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2" ry="2"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
                            } else {
                                <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
                            }
                        </div>
                        
                        <div class="flex-1">
                            <div class="flex items-center justify-between">
                                <div>
                                    <h3 class="text-xl font-black text-[#0A1F44]">@inc.Type</h3>
                                    <p class="text-sm font-bold text-[#0B6623] mt-0.5">@inc.Context.Student</p>
                                </div>
                                <div class="text-right">
                                    <p class="text-xs font-bold text-slate-400 uppercase tracking-widest">@inc.CreatedAt.ToString("dd/MM/yyyy")</p>
                                    <StatusBadge Status="@inc.Status" />
                                </div>
                            </div>
                            <p class="mt-4 text-slate-500 font-medium leading-relaxed">@inc.Description</p>
                            
                            <div class="mt-6 pt-4 border-t border-slate-50 flex items-center justify-end gap-2">
                                <button @onclick="() => ResolveIncident(inc.Id)" class="px-4 py-2 rounded-xl text-xs font-bold text-[#0A1F44] hover:bg-slate-50 transition-colors">Resolver</button>
                                <button @onclick="() => DeleteIncident(inc.Id)" class="px-4 py-2 rounded-xl text-xs font-bold text-slate-400 hover:text-red-500 transition-colors">Eliminar</button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

@if (isCreateModalVisible)
{
    <div class="liggo-modal-overlay" @onclick="() => isCreateModalVisible = false">
        <div class="liggo-modal-content" @onclick:stopPropagation="true">
            <h2 class="text-2xl font-black text-[#0A1F44] mb-6">Reportar Incidente</h2>
            <EditForm Model="@newIncident" OnValidSubmit="HandleCreateIncident">
                <DataAnnotationsValidator />
                <div class="space-y-5">
                    @if (!string.IsNullOrEmpty(errorMessage))
                    {
                        <div class="p-4 bg-red-50 text-red-600 rounded-xl text-sm font-bold border border-red-100 transition-all">
                            @errorMessage
                        </div>
                    }

                    <div>
                        <label class="block text-sm font-bold text-slate-400 uppercase tracking-widest mb-2">Jugador</label>
                        <InputSelect @bind-Value="newIncident.PlayerId" class="w-full px-4 py-3 bg-slate-50 border-0 rounded-xl focus:ring-2 focus:ring-[#0B6623] font-medium outline-none transition-all">
                            <option value="">Seleccione un jugador...</option>
                            @if(players != null)
                            {
                                @foreach(var player in players)
                                {
                                    <option value="@player.Id.ToString()">@player.FullName</option>
                                }
                            }
                        </InputSelect>
                        <ValidationMessage For="@(() => newIncident.PlayerId)" class="text-red-500 text-xs mt-1" />
                    </div>
                    
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="block text-sm font-bold text-slate-400 uppercase tracking-widest mb-2">Tipo</label>
                            <InputSelect @bind-Value="newIncident.Type" class="w-full px-4 py-3 bg-slate-50 border-0 rounded-xl focus:ring-2 focus:ring-[#0B6623] font-medium outline-none transition-all">
                                <option value="Sanction">Sanción</option>
                                <option value="Injury">Lesión</option>
                                <option value="Administrative">Administrativo</option>
                            </InputSelect>
                        </div>
                        <div>
                            <label class="block text-sm font-bold text-slate-400 uppercase tracking-widest mb-2">Gravedad</label>
                            <InputSelect @bind-Value="newIncident.Severity" class="w-full px-4 py-3 bg-slate-50 border-0 rounded-xl focus:ring-2 focus:ring-[#0B6623] font-medium outline-none transition-all">
                                <option value="Minor">Leve</option>
                                <option value="Moderate">Moderada</option>
                                <option value="Major">Grave</option>
                            </InputSelect>
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-bold text-slate-400 uppercase tracking-widest mb-2">Descripción</label>
                        <InputTextArea @bind-Value="newIncident.Description" class="w-full px-4 py-3 bg-slate-50 border-0 rounded-xl focus:ring-2 focus:ring-[#0B6623] font-medium outline-none transition-all h-32 resize-none" placeholder="Detalles del incidente..."></InputTextArea>
                        <ValidationMessage For="@(() => newIncident.Description)" class="text-red-500 text-xs mt-1" />
                    </div>
                </div>
                
                <div class="flex gap-4 mt-8">
                    <button type="button" @onclick="() => isCreateModalVisible = false" class="flex-1 py-4 px-6 rounded-xl font-bold text-slate-400 hover:bg-slate-50 transition-all">
                        Cancelar
                    </button>
                    <button type="submit" disabled="@isLoading" class="flex-[2] py-4 px-6 bg-[#0B6623] hover:bg-[#0A1F44] text-white rounded-xl font-bold shadow-lg shadow-[#0B6623]/20 transition-all disabled:opacity-50">
                        @(isLoading ? "Guardando..." : "Guardar Reporte")
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
}

@code {
    private List<PlayerDto> players = new();
    private List<IncidentDto> incidents = new();
    private CreateIncidentRequest newIncident = new() 
    { 
        Type = "Sanction", 
        Severity = "Minor", 
        Status = "Active",
        Context = new() { Student = "", Event = "" }
    };
    private bool isCreateModalVisible = false;
    private bool isLoading = false;
    private string errorMessage = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        players = await PlayerService.GetPlayersAsync();
        incidents = await IncidentService.GetIncidentsAsync();
    }

    private void ShowCreateModal()
    {
        var selectedPlayerId = players.FirstOrDefault()?.Id;
        newIncident = new() 
        { 
            Type = "Sanction", 
            Severity = "Minor", 
            Status = "Active",
            PlayerId = selectedPlayerId?.ToString() ?? "",
            Context = new() { Student = "", Event = "Manual Report" } // INITIALIZE CONTEXT
        };
        isCreateModalVisible = true;
    }

    private async Task HandleCreateIncident()
    {
        if (string.IsNullOrEmpty(newIncident.PlayerId))
        {
            errorMessage = "Debe seleccionar un jugador.";
            return;
        }

        errorMessage = "";
        try
        {
            var player = players.FirstOrDefault(p => p.Id.ToString() == newIncident.PlayerId);
            newIncident.Context.Student = player?.FullName ?? "Unknown";
            if (string.IsNullOrEmpty(newIncident.Context.Event)) newIncident.Context.Event = "Manual Report";

            isLoading = true;
            Console.WriteLine($"Sending incident for player {newIncident.PlayerId}: {System.Text.Json.JsonSerializer.Serialize(newIncident)}");
            await IncidentService.CreateIncidentAsync(newIncident);
            isCreateModalVisible = false;
            await LoadData();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al guardar: {ex.Message}";
            Console.WriteLine($"Error creating incident: {ex.Message}");
            if (ex is HttpRequestException httpEx)
            {
                Console.WriteLine($"Status Code: {httpEx.StatusCode}");
            }
        }
        finally
        {
            isLoading = false;
        }
    }

    private async Task ResolveIncident(Guid incidentId)
    {
        await IncidentService.UpdateIncidentAsync(incidentId, new UpdateIncidentRequest { Status = "Resolved" });
        incidents = await IncidentService.GetIncidentsAsync();
    }

    private async Task DeleteIncident(Guid incidentId)
    {
        await IncidentService.DeleteIncidentAsync(incidentId);
        incidents = await IncidentService.GetIncidentsAsync();
    }
}
