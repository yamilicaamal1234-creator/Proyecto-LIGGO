@page "/attendance"
@inject NavigationManager Nav
@inject AttendanceService AttendanceSvc
@inject PlayerService PlayerSvc
@using liggo_blazor.Models

<div class="space-y-6 animate-in fade-in slide-in-from-bottom-4 duration-700">
    <div class="rounded-xl bg-white shadow-sm border border-slate-100">
        <div class="p-6 border-b border-slate-100 flex justify-between items-center">
            <div>
                <h3 class="text-xl font-black text-[#0A1F44]">Control General de Asistencia</h3>
                <p class="text-sm font-medium text-slate-500">Pase de lista de todos los jugadores de la academia</p>
            </div>
            <button @onclick="HandleSaveAttendance" class="px-6 py-3 rounded-xl bg-[#0B6623] text-white font-bold hover:bg-[#0A1F44] transition-colors shadow-lg shadow-[#0B6623]/20">Guardar Asistencia</button>
        </div>
        <div class="p-6 space-y-3">
            @if(attendanceViewModels == null)
            {
                <div class="flex items-center justify-center py-10">
                    <p class="text-slate-500 font-medium">Cargando jugadores...</p>
                </div>
            }
            else
            {
                @foreach (var attendance in attendanceViewModels)
                {
                    <div class="flex items-center justify-between rounded-2xl border border-slate-100 p-4 hover:border-slate-200 transition-colors shadow-sm bg-slate-50/30">
                        <div class="flex items-center gap-4">
                            <div class="h-10 w-10 rounded-full bg-slate-200 flex items-center justify-center font-bold text-slate-500 uppercase">
                                @(attendance.PlayerName.Length > 0 ? attendance.PlayerName.Substring(0,1) : "P")
                            </div>
                            <p class="text-base font-bold text-[#0A1F44]">@attendance.PlayerName</p>
                        </div>
                        <div class="flex gap-2">
                            <button @onclick="() => CycleStatus(attendance)" 
                                    style="background-color: @GetStatusHex(attendance.Status); color: @GetStatusTextColor(attendance.Status); border-color: rgba(0,0,0,0.1);"
                                    class="px-5 py-2 text-base font-bold rounded-xl transition-all min-w-[140px] shadow-sm active:scale-95 border-2 flex items-center justify-center">
                                @GetStatusLabel(attendance.Status)
                            </button>
                        </div>
                    </div>
                }
            }
        </div>
    </div>
</div>

@code {
    private List<AttendanceViewModel>? attendanceViewModels;

    public class AttendanceViewModel
    {
        public Guid PlayerId { get; set; }
        public string PlayerName { get; set; } = string.Empty;
        public AttendanceStatus Status { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        var allPlayers = await PlayerSvc.GetPlayersAsync();

        // Control de asistencia general de todos los jugadores
        attendanceViewModels = allPlayers.Select(p => new AttendanceViewModel
        {
            PlayerId = p.Id,
            PlayerName = p.FullName,
            Status = AttendanceStatus.Present // Por defecto presentes
        }).ToList();
    }

    private async Task HandleSaveAttendance()
    {
        if (attendanceViewModels == null) return;

        var request = new SaveAttendanceRequest
        {
            MatchId = Guid.Empty, // Sin ID de partido específico
            Attendances = attendanceViewModels.Select(vm => new AttendanceRecordRequest
            {
                PlayerId = vm.PlayerId,
                Status = vm.Status
            })
        };

        try
        {
            await AttendanceSvc.SaveAttendanceAsync(request);
            Nav.NavigateTo("/dashboard");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error saving attendance: {ex.Message}");
        }
    }

    private void CycleStatus(AttendanceViewModel vm)
    {
        vm.Status = vm.Status switch
        {
            AttendanceStatus.Present => AttendanceStatus.Tardy,
            AttendanceStatus.Tardy => AttendanceStatus.Absent,
            AttendanceStatus.Absent => AttendanceStatus.Justified,
            AttendanceStatus.Justified => AttendanceStatus.Present,
            _ => AttendanceStatus.Present
        };
        StateHasChanged();
    }

    private string GetStatusLabel(AttendanceStatus status) => status switch
    {
        AttendanceStatus.Present => "PRESENTE",
        AttendanceStatus.Absent => "AUSENTE",
        AttendanceStatus.Justified => "JUSTIFICADO",
        AttendanceStatus.Tardy => "RETARDO",
        _ => "PRESENTE"
    };

    private string GetStatusHex(AttendanceStatus status) => status switch
    {
        AttendanceStatus.Present => "#22c55e",
        AttendanceStatus.Absent => "#dc2626",
        AttendanceStatus.Justified => "#facc15",
        AttendanceStatus.Tardy => "#f97316",
        _ => "#cbd5e1"
    };

    private string GetStatusTextColor(AttendanceStatus status) => status switch
    {
        AttendanceStatus.Absent => "#ffffff",
        _ => "#000000"
    };
}
