@page "/matches"
@inject NavigationManager Nav
@inject MatchService MatchSvc
@using liggo_blazor.Models

<div class="space-y-8 animate-in fade-in slide-in-from-bottom-4 duration-700">
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-3xl font-black text-[#0A1F44]">Partidos</h1>
            <p class="text-slate-500 font-medium">Calendario de encuentros y registro de resultados.</p>
        </div>
        <button @onclick="ShowCreateModal" class="bg-[#0A1F44] hover:bg-[#0B6623] text-white px-6 py-3 rounded-xl font-bold transition-all shadow-lg shadow-[#0A1F44]/20 flex items-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Programar Partido
        </button>
    </div>

    <div class="grid gap-6">
        @if (matches == null)
        {
            <p>Cargando partidos...</p>
        }
        else if (!matches.Any())
        {
            <p>No hay partidos programados.</p>
        }
        else
        {
            @foreach (var match in matches)
            {
                <div class="group relative overflow-hidden rounded-3xl bg-white p-6 shadow-[0_4px_20px_rgba(0,0,0,0.05)] border border-slate-50 transition-all hover:shadow-[0_15px_30px_rgba(0,0,0,0.08)]">
                    <div class="flex flex-col md:flex-row items-center justify-between gap-8">
                        <div class="flex-1 text-center md:text-right">
                            <p class="text-lg font-black text-[#0A1F44]">@match.LocalTeam</p>
                            <p class="text-xs font-bold text-[#0B6623] uppercase tracking-widest mt-1">Local</p>
                        </div>
                        <div class="flex flex-col items-center shrink-0 px-8 py-2 border-x border-slate-100">
                            <span class="text-sm font-bold text-slate-400">VS</span>
                        </div>
                        <div class="flex-1 text-center md:text-left">
                            <p class="text-lg font-black text-[#0A1F44]">@match.VisitingTeam</p>
                            <p class="text-xs font-bold text-[#0B6623] uppercase tracking-widest mt-1">Visitante</p>
                        </div>
                    </div>
                    <div class="mt-6 pt-4 border-t border-slate-50 flex flex-wrap items-center justify-center gap-6 text-xs font-bold text-slate-400 uppercase tracking-widest">
                        <div class="flex items-center gap-2">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
                            @match.DateTime.ToString("g")
                        </div>
                        <div class="flex items-center gap-2">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
                            @match.Location
                        </div>
                        <div class="flex items-center gap-2">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M6 12 3 9l3-3"/><path d="m18 6 3 3-3 3"/><path d="M13 3l-2 18"/></svg>
                            @match.Category
                        </div>
                    </div>
                    <div class="absolute right-4 top-4 flex gap-2">
                        <button @onclick='() => Nav.NavigateTo($"/attendance/{match.Id}")' class="p-2 bg-[#0B6623]/5 hover:bg-[#0B6623] hover:text-white text-[#0B6623] rounded-xl transition-all shadow-sm" title="Tomar Asistencia">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>
                        </button>
                        <button @onclick="() => DeleteMatch(match.Id)" class="p-2 bg-red-50 hover:bg-red-600 text-red-600 hover:text-white rounded-xl transition-all shadow-sm" title="Eliminar Partido">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
                        </button>
                    </div>
                </div>
            }
        }
    </div>
</div>

@if (isCreateModalVisible)
{
    <div class="liggo-modal-overlay" @onclick="() => isCreateModalVisible = false">
        <div class="liggo-modal-content" @onclick:stopPropagation="true">
            <h2 class="text-2xl font-bold text-[#0A1F44] mb-4">Programar Partido</h2>
            <EditForm Model="@newMatch" OnValidSubmit="HandleCreateMatch">
                <DataAnnotationsValidator />
                <div class="space-y-4">
                    <div class="grid grid-cols-2 gap-4">
                        <div>
                            <label class="font-medium">Equipo Local</label>
                            <InputText @bind-Value="newMatch.LocalTeam" class="w-full p-2 border rounded" />
                        </div>
                        <div>
                            <label class="font-medium">Equipo Visitante</label>
                            <InputText @bind-Value="newMatch.VisitingTeam" class="w-full p-2 border rounded" />
                        </div>
                    </div>
                    <div>
                        <label class="font-medium">Fecha y Hora</label>
                        <InputDate Type="InputDateType.DateTimeLocal" @bind-Value="newMatch.DateTime" class="w-full p-2 border rounded" />
                    </div>
                    <div>
                        <label class="font-medium">Ubicación</label>
                        <InputText @bind-Value="newMatch.Location" class="w-full p-2 border rounded" />
                    </div>
                    <div>
                        <label class="font-medium">Categoría</label>
                        <InputSelect @bind-Value="newMatch.Category" class="w-full p-2 border rounded">
                            @foreach (var cat in Enum.GetValues(typeof(MatchCategory)))
                            {
                                <option value="@cat">@cat</option>
                            }
                        </InputSelect>
                    </div>
                </div>
                <div class="flex justify-end gap-4 mt-6">
                    <button type="button" @onclick="() => isCreateModalVisible = false" class="px-4 py-2 rounded bg-gray-200 hover:bg-gray-300">Cancelar</button>
                    <button type="submit" class="px-4 py-2 rounded bg-[#0A1F44] text-white hover:bg-[#0B6623]">Programar</button>
                </div>
            </EditForm>
        </div>
    </div>
}

@code {
    private List<MatchDto>? matches;
    private bool isCreateModalVisible = false;
    private CreateMatchRequest newMatch = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadMatches();
    }

    private async Task LoadMatches()
    {
        matches = await MatchSvc.GetMatchesAsync();
    }

    private void ShowCreateModal()
    {
        newMatch = new();
        isCreateModalVisible = true;
    }

    private async Task HandleCreateMatch()
    {
        try
        {
            await MatchSvc.CreateMatchAsync(newMatch);
            isCreateModalVisible = false;
            await LoadMatches();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error creating match: {ex.Message}");
        }
    }

    private async Task DeleteMatch(Guid id)
    {
        try
        {
            await MatchSvc.DeleteMatchAsync(id);
            await LoadMatches();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error deleting match: {ex.Message}");
        }
    }
}
